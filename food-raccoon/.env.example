# Copy this file to .env (never commit the copy) and export these values before
# starting the optional local Food Raccoon backend.
AMAP_API_KEY=
DEEPSEEK_API_KEY=
FOOD_RACCOON_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
FOOD_RACCOON_RATE_LIMIT=10
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
PORT=5000
